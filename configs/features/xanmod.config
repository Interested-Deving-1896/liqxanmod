# XanMod throughput-optimised config fragment
# Applied in xanmod and hybrid modes.

# Scheduler
CONFIG_HZ_1000=y
CONFIG_HZ=1000
# CONFIG_HZ_250 is not set
# CONFIG_HZ_300 is not set

# Preemption — voluntary for throughput
CONFIG_PREEMPT_VOLUNTARY=y
# CONFIG_PREEMPT is not set
# CONFIG_PREEMPT_NONE is not set

# CPU frequency — performance governor default
CONFIG_CPU_FREQ_DEFAULT_GOV_PERFORMANCE=y
# CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL is not set
# CONFIG_CPU_FREQ_DEFAULT_GOV_ONDEMAND is not set

# Memory — reduce overhead
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_TRANSPARENT_HUGEPAGE_ALWAYS=y
# CONFIG_TRANSPARENT_HUGEPAGE_MADVISE is not set

# Network — BBR2 + FQ
CONFIG_TCP_CONG_BBR=y
CONFIG_NET_SCH_FQ=y
CONFIG_NET_SCH_FQ_CODEL=y
CONFIG_DEFAULT_TCP_CONG="bbr"

# IRQ balancing
CONFIG_IRQ_TIME_ACCOUNTING=y

# Disable unnecessary debug overhead
# CONFIG_DEBUG_KERNEL is not set
# CONFIG_SLUB_DEBUG is not set
# CONFIG_DEBUG_PAGEALLOC is not set

# XanMod identity
CONFIG_LOCALVERSION="-liqxanmod"
