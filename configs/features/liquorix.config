# Liquorix/Zen low-latency config fragment
# Applied in liquorix and hybrid modes.

# Scheduler — full preemption for low latency
CONFIG_PREEMPT=y
# CONFIG_PREEMPT_VOLUNTARY is not set
# CONFIG_PREEMPT_NONE is not set

# HZ — 1000 for fine-grained timekeeping
CONFIG_HZ_1000=y
CONFIG_HZ=1000

# CPU frequency — schedutil for responsive scaling
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y
# CONFIG_CPU_FREQ_DEFAULT_GOV_PERFORMANCE is not set

# Memory — low-latency page reclaim
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_TRANSPARENT_HUGEPAGE_MADVISE=y
# CONFIG_TRANSPARENT_HUGEPAGE_ALWAYS is not set

# MuQSS / Zen scheduler tunables are set via patches; these fragments
# configure the surrounding kernel options.

# Realtime group scheduling — off for lower latency
# CONFIG_RT_GROUP_SCHED is not set

# Disable group scheduling overhead for desktop use
# CONFIG_FAIR_GROUP_SCHED is not set

# Timer slack — tighter for interactive responsiveness
CONFIG_HZ_PERIODIC=y

# Zen identity
CONFIG_LOCALVERSION="-liqxanmod"
