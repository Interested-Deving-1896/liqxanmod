# LiqXanMod hybrid-mode config fragment
# Applied on top of xanmod.config + liquorix.config in hybrid and auto modes.
# Resolves conflicts between the two fragments and enables the runtime
# autodetect module.

# Enable the hybrid autodetect subsystem
CONFIG_LIQXANMOD_HYBRID=y

# Preemption — PREEMPT wins over PREEMPT_VOLUNTARY in hybrid mode.
# The autodetect module adjusts scheduler tunables at runtime; the preemption
# model itself is fixed at compile time. PREEMPT gives the best worst-case
# latency while remaining acceptable for throughput workloads.
CONFIG_PREEMPT=y
# CONFIG_PREEMPT_VOLUNTARY is not set

# CPU frequency — schedutil is compatible with both profiles; the autodetect
# module does not change the governor, only the CFS tunables.
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y
# CONFIG_CPU_FREQ_DEFAULT_GOV_PERFORMANCE is not set

# Transparent hugepages — madvise lets applications opt in; avoids the
# latency spikes that ALWAYS mode causes for latency-sensitive workloads.
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_TRANSPARENT_HUGEPAGE_MADVISE=y
# CONFIG_TRANSPARENT_HUGEPAGE_ALWAYS is not set

# schedstats required for wakeup-rate sampling in the autodetect module
CONFIG_SCHEDSTATS=y

# sched debug required for sysfs tunable bridge
CONFIG_SCHED_DEBUG=y

# Localversion
CONFIG_LOCALVERSION="-liqxanmod-hybrid"
